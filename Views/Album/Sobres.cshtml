            else if(jugador.Nombre == "Jude Bellingham"){
                <img src="~/images/jugadores/bellingham.svg" width="180">
            }
            else if(jugador.Nombre == "Bukayo Saka"){
                <img src="~/images/jugadores/saka.svg" width="180">
            }
            else if(jugador.Nombre == "Marcus Rashford"){
                <img src="~/images/jugadores/rashford.svg" width="180">
            }
            else if(jugador.Nombre == "Jordan Pickford"){
                <img src="~/images/jugadores/pickford.svg" width="180">
            }
        </div>
    }

}
